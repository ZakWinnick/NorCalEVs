---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found · NorCal EVs" description="That page doesn't exist.">
  <section class="page-head">
    <div class="container">
      <span class="kicker">Error 404</span>
      <h1>This road doesn't go anywhere.</h1>
      <p class="page-lede">The page you're looking for moved or never existed. Let's get you back on route.</p>
      <div class="cta-row">
        <a href="/" class="btn btn-primary">Back to Home</a>
        <a href="/membership" class="btn btn-ghost">Join the Community</a>
      </div>
    </div>
  </section>
</BaseLayout>
