---
import BaseLayout from "../layouts/BaseLayout.astro";

// Launch Edition promo: Long Range at $30 for the first year, first 30 members.
// No payment backend yet, so launchClaimed is maintained by hand. When it
// reaches launchTotal the banner drops off automatically (per spec).
const launchClaimed = 0;
const launchTotal = 30;

const funnel = [
  { n: "01", t: "Discover", d: "Hear about NorCal EVs from a friend, an event, or online." },
  { n: "02", t: "Learn", d: "Visit the site and get what we're about in under 30 seconds." },
  { n: "03", t: "Join", d: "Sign up in our online hub and pick a tier that fits you." },
  { n: "04", t: "Attend", d: "Come to your first event. First one is always free." },
  { n: "05", t: "Stay", d: "Keep coming back. That's the whole thing." },
];

const benefits = [
  "Access to every event, discussion, and member communication (all tiers)",
  "Free admission to member-only events (Long Range and up)",
  "Tier-based discounts on paid events and the NorCal EVs shop (Long Range and Max Pack)",
  "Voting rights on community decisions (Long Range and Max Pack)",
  "A NorCal EVs member sticker (Long Range and up)",
  "Real-world community: drives, meetups, and shared experiences across every brand",
];
---

<BaseLayout
  title="Membership · NorCal EVs"
  description="Pick how you want to be part of NorCal EVs. Free for everyone, with paid tiers for members who want to go deeper and support what we're building."
>
  <section class="page-head">
    <div class="container">
      <span class="kicker">Open Membership</span>
      <h1>Join the community, then show up.</h1>
      <p class="page-lede">
        NorCal EVs is a registered 501(c)(7) community open to anyone in Northern California who
        owns, leases, or is curious about electric vehicles. No specific brand, model, or
        ownership status required. If you're EV-curious and trying to figure out your first EV,
        you belong here too.
      </p>
      <div class="cta-row">
        <a href="/join" class="btn btn-primary">Join the Community</a>
        <a href="/#events" class="btn btn-ghost">View Upcoming Events</a>
      </div>
      <p class="tile-muted" style="margin-top:24px">Your first event is always free</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">How It Works</span>
        <h2 class="section-title">Five steps. No friction.</h2>
      </div>
      <div class="funnel">
        {funnel.map((s) => (
          <div class="funnel-step">
            <span class="funnel-num">{s.n}</span>
            <div class="funnel-label">{s.t}</div>
            <p class="funnel-desc">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Tiers</span>
        <h2 class="section-title">Pick what fits. Upgrade when it makes sense.</h2>
      </div>

      {launchClaimed < launchTotal && (
        <div class="promo">
          <div>
            <span class="promo-badge">Launch Edition</span>
            <h3>Long Range for $30 your first year.</h3>
            <p>A founding rate for the first 30 members. It renews at $50 a year after that. Once 30 spots are claimed, this offer is gone.</p>
          </div>
          <a href="/join" class="btn btn-primary">Claim the Launch Rate</a>
        </div>
      )}

      <div class="tiers t3">
        <div class="tier">
          <div class="tier-name">Standard Range</div>
          <div class="tier-price">Free</div>
          <p class="tier-for">For anyone who wants in.</p>
          <ul>
            <li>Access to all events</li>
            <li>Community discussions and member communications</li>
            <li>A way to join the community and see what NorCal EVs is about</li>
          </ul>
          <a href="/join" class="btn btn-ghost">Join Free</a>
        </div>

        <div class="tier feature">
          <span class="tier-badge">Best Value</span>
          <div class="tier-name">Long Range</div>
          <div class="tier-price">$50 <span>/ year</span></div>
          <p class="tier-for">For members who want to go deeper.</p>
          <ul>
            <li>Everything in Standard Range</li>
            <li>Free admission to member-only events</li>
            <li>20% off paid events</li>
            <li>10% off the NorCal EVs shop</li>
            <li>Voting rights on community decisions</li>
            <li>NorCal EVs member sticker included</li>
          </ul>
          <a href="/join" class="btn btn-primary">Choose Long Range</a>
        </div>

        <div class="tier">
          <div class="tier-name">Max Pack</div>
          <div class="tier-price">$500 <span>lifetime</span></div>
          <p class="tier-for">For the all-in founding supporters.</p>
          <ul>
            <li>Everything in Long Range, forever</li>
            <li>50% off paid events</li>
            <li>50% off the NorCal EVs shop at signup</li>
            <li>Permanent recognition on the website and in the community</li>
            <li>NorCal EVs member sticker included</li>
          </ul>
          <a href="/join" class="btn btn-ghost">Go Max Pack</a>
        </div>
      </div>

      <p class="section-desc" style="margin-top:28px">
        Being part of NorCal EVs has always been free, and that's not changing. Paid
        memberships are for people who want to support what we're building, get more out of the
        community, and have a say in where it goes.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">What Members Get</span>
        <h2 class="section-title">Real community benefits, listed honestly.</h2>
      </div>
      <ul class="list-check two-col">
        {benefits.map((b) => <li>{b}</li>)}
      </ul>
    </div>
  </section>

  <section class="section band-cta">
    <div class="container">
      <span class="kicker on-dark">All Brands Welcome</span>
      <h2 class="section-title" style="margin-top:20px">From Tesla to Kia to "still deciding."</h2>
      <p>
        The community is bigger than any one manufacturer. The best conversations happen when
        longtime EV owners, first-time buyers, and EV-curious newcomers all end up in the same
        parking lot.
      </p>
    </div>
  </section>
</BaseLayout>
