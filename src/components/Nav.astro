---
import { navigation } from "../data/navigation";
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-brand">
      <img src="/assets/images/logo-400.png" alt="NorCal EVs" width="46" height="46" />
      <span class="wordmark">NorCal EVs</span>
    </a>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-menu" id="nav-menu">
      <ul class="nav-links">
        {navigation.map((item) =>
          item.submenu ? (
            <li class="nav-has-sub">
              <a href={item.url}>{item.title} <span aria-hidden="true">▾</span></a>
              <ul class="nav-sub">
                {item.submenu.map((sub) => (
                  <li>
                    <a href={sub.url} target="_blank" rel="noopener noreferrer">
                      {sub.title} <span class="ext-arrow" aria-hidden="true">↗</span>
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ) : (
            <li>
              <a href={item.url} {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
                {item.title}
                {item.external && <span class="ext-arrow" aria-hidden="true">↗</span>}
              </a>
            </li>
          )
        )}
      </ul>
      <a href="/membership" class="nav-cta">Join the Community</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const menu = document.getElementById("nav-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(!!open));
  });
</script>
