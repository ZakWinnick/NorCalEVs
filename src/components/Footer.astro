---
import { social } from "../data/social";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <div class="footer-brand">
        <img src="/assets/images/logo-400.png" alt="NorCal EVs" width="58" height="58" />
        <span class="wordmark">NorCal EVs</span>
      </div>
      <p class="footer-tagline">Driven by Community. If it plugs in, it belongs here. Northern California's cross-brand EV community.</p>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <ul>
        <li><a href="/membership">Membership</a></li>
        <li><a href="/sponsorships">Sponsorships</a></li>
        <li><a href="/resources">Resources</a></li>
        <li><a href="/leaders">Leaders</a></li>
        <li><a href="https://shop.norcalevs.org" target="_blank" rel="noopener noreferrer">Shop ↗</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Connect</h4>
      <ul>
        {social.map((s) => (
          <li><a href={s.url} target="_blank" rel="noopener noreferrer">{s.name} ↗</a></li>
        ))}
        <li><a href="mailto:info@norcalevs.org">info@norcalevs.org</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; {year} NorCal EVs. A registered 501(c)(7) community.</span>
    <span><a href="/privacy">Privacy</a> &nbsp;·&nbsp; <a href="/terms">Terms</a></span>
  </div>
</footer>
